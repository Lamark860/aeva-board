# aeva-board — Kanboard за общим Traefik.
# Скопируй в .env и заполни. .env в git НЕ коммитим (см. .gitignore).

# Поддомен доски. Traefik роутит по нему и выпускает Let's Encrypt cert.
# Перед деплоем заведи DNS A-запись этого имени → IP сервера.
DOMAIN=board.aevashop.ru

# Пароль Postgres. Сгенерируй: openssl rand -base64 32
DB_PASSWORD=

# Опц.: пин версии образа вместо latest (рекомендуется для прода —
# предсказуемые апдейты). Список тегов: hub.docker.com/r/kanboard/kanboard/tags
# KANBOARD_IMAGE=kanboard/kanboard:v1.2.46

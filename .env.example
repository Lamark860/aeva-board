# aeva-board — Vikunja за общим Traefik.
# Скопируй в .env и заполни. .env в git НЕ коммитим (см. .gitignore).

# Поддомен доски. Traefik роутит по нему и выпускает Let's Encrypt cert.
# Перед деплоем заведи DNS A-запись этого имени → IP сервера.
DOMAIN=board.aevashop.ru

# Пароль Postgres. Сгенерируй: openssl rand -base64 32
DB_PASSWORD=

# Секрет подписи JWT-сессий Vikunja — ОБЯЗАТЕЛЬНО свой. Сгенерируй: openssl rand -hex 32
VIKUNJA_SECRET=

# Публичная регистрация. На публичном проде держим false (юзеров заводим
# через CLI: docker compose exec vikunja /app/vikunja/vikunja user create ...).
# На время первичной настройки можно временно поставить true. По умолчанию false.
# VIKUNJA_REGISTRATION=false

# Опц.: пин версии образа (рекомендуется для прода — предсказуемые апдейты).
# Список тегов: hub.docker.com/r/vikunja/vikunja/tags
# VIKUNJA_IMAGE=vikunja/vikunja:latest
